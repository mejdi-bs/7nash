generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String?
  highScore    Int      @default(0)
  selectedSkin String   @default("classic")
  privateSkins String   @default("") // Comma-separated list of private skin IDs
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteStats {
  id              String   @id @default("site-stats")
  totalPlayers    Int      @default(0) // Total unique players who opened game
  updatedAt       DateTime @updatedAt
}

model DailyPlayerVisit {
  id        String   @id @default(cuid())
  date      DateTime
  username  String
  createdAt DateTime @default(now())

  @@unique([date, username]) // One record per user per day
}
